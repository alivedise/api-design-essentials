      "Problem": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "format": "uri-reference",
            "description": "A URI reference that uniquely identifies the problem type in the context of the provided API.\n",
            "default": "about:blank",
            "example": "/some/uri-reference"
          },
          "title": {
            "type": "string",
            "description": "A short summary of the problem type. Written in English and readable for engineers,  usually not suited for non-technical stakeholders and not localized.\n",
            "example": "some title for the error situation"
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "description": "The HTTP status code generated by the origin server for this occurrence of the problem.\n",
            "minimum": 100,
            "maximum": 600,
            "exclusiveMaximum": 600
          },
          "detail": {
            "type": "string",
            "description": "A human-readable explanation specific to this occurrence of the problem, helping to  pinpoint the problem and providing advice on how to proceed. Written in English and  readable for engineers, usually not suited for non-technical stakeholders and not localized.\n",
            "example": "some description for the error situation"
          },
          "instance": {
            "type": "string",
            "format": "uri-reference",
            "description": "A URI reference that identifies the specific occurrence of the problem, e.g. by adding  a fragment identifier or sub-path to the problem type. May be used to locate the root  cause of this problem occurrence in the source code.\n",
            "example": "/some/uri-reference#specific-occurrence-context"
          }
        },
        "required": [
          "type",
          "title",
          "status"
        ]
      },
      "Unauthorized": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Problem"
          },
          {
            "properties": {
              "status": {
                "type": "integer",
                "example": 401
              },
              "title": {
                "type": "string",
                "example": "Unauthorized"
              },
              "detail": {
                "type": "string",
                "example": "Authentication is required and has failed or has not yet been provided."
              }
            }
          }
        ]
      },
      "Forbidden": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Problem"
          },
          {
            "properties": {
              "status": {
                "type": "integer",
                "example": 403
              },
              "title": {
                "type": "string",
                "example": "Forbidden"
              },
              "detail": {
                "type": "string",
                "example": "The request was a valid request, but the server is refusing to respond to it."
              }
            }
          }
        ]
      },
      "Idempotency-Key": {
        "description": "The **Idempotency-Key** is a free identifier created by the client to\nidentify a request. It is used by the service to identify repeated request\nto ensure idempotent behavior by sending the same (or a similar) response\nwithout executing the request a second time.\n\nClients should be careful as any subsequent requests with the same key may\nreturn the same response without further check. Thus, it is recommended to\nuse a UUID version 4 (random) or any other random string with enough\nentropy to avoid collisions.\n\nKeys expire after 24 hours. Clients are responsible to stay within this\nlimit, if they require idempotent behavior.\n\nSee [API Design Essentials-130][ade-130] for further details.\n\n[ade-130]: <https://alivedise.github.io/api-design-essentials/130>",
        "type": "string",
        "format": "uuid",
        "example": "7da7a728-f910-11e6-942a-68f728c1ba70"
      },
      "BadRequest": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Problem"
          },
          {
            "properties": {
              "status": {
                "type": "integer",
                "example": 400
              },
              "title": {
                "type": "string",
                "example": "Bad Request"
              },
              "detail": {
                "type": "string",
                "example": "The request could not be understood by the server due to malformed syntax."
              }
            }
          }
        ]
      },
      "NotFound": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Problem"
          },
          {
            "properties": {
              "status": {
                "type": "integer",
                "example": 404
              },
              "title": {
                "type": "string",
                "example": "Not Found"
              },
              "detail": {
                "type": "string",
                "example": "The requested resource could not be found but may be available in the future."
              }
            }
          }
        ]
      },
      "CloudEvent": {
        "type": "object",
        "required": [
          "specversion",
          "type",
          "source",
          "id"
        ],
        "properties": {
          "specversion": {
            "type": "string",
            "enum": [
              "1.0"
            ]
          },
          "type": {
            "type": "string",
            "description": "Event type following [ADE-603](https://alivedise.github.io/api-design-essentials/603) naming conventions",
            "example": "com.example.someevent.v1.occurred"
          },
          "source": {
            "type": "string",
            "format": "uri-reference",
            "description": "Event source following [ADE-604](https://alivedise.github.io/api-design-essentials/604) guidelines",
            "example": "https://example.com/v1/planets/earth"
          },
          "id": {
            "type": "string",
            "description": "Event identifier"
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "description": "Event occurrence time or received time ([ADE-605](https://alivedise.github.io/api-design-essentials/605))"
          },
          "datacontenttype": {
            "type": "string",
            "default": "application/json"
          },
          "data": {
            "type": "object",
            "description": "Event payload"
          },
          "test": {
            "type": "string",
            "pattern": "^[a-z]+\\.[a-z]+$",
            "description": "Test marker following [ADE-606](https://alivedise.github.io/api-design-essentials/606) guidelines"
          },
          "partitionkey": {
            "type": "string",
            "description": "Partition key for event routing ([ADE-609](https://alivedise.github.io/api-design-essentials/609))"
          },
          "sequence": {
            "type": "string",
            "description": "Event sequence for ordering ([ADE-610](https://alivedise.github.io/api-design-essentials/610))"
          },
          "severity": {
            "type": "string",
            "enum": [
              "TRACE",
              "DEBUG",
              "INFO",
              "WARN",
              "ERROR",
              "FATAL"
            ],
            "description": "Event severity level ([ADE-611](https://alivedise.github.io/api-design-essentials/611))"
          },
          "recordedtime": {
            "type": "string",
            "format": "date-time",
            "description": "Time when the event was recorded ([ADE-612](https://alivedise.github.io/api-design-essentials/612))"
          },
          "expirytime": {
            "type": "string",
            "format": "date-time",
            "description": "Expiration time for temporary events ([ADE-608](https://alivedise.github.io/api-design-essentials/608))"
          },
          "traceparent": {
            "type": "string",
            "description": "Trace context for distributed tracing ([ADE-607](https://alivedise.github.io/api-design-essentials/607))",
            "example": "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01"
          },
          "tracestate": {
            "type": "string",
            "description": "Trace state for distributed tracing ([ADE-607](https://alivedise.github.io/api-design-essentials/607))",
            "example": "congo=t61rcWkgMzE"
          }
        }
      }
    },
    "responses": {
      "400": {
        "description": "Bad Request",
        "content": {
